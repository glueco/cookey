# Demo Target App Environment Variables

# Private key for signing PoP requests (base64-encoded Ed25519 seed, 32 bytes)
# Generate with: openssl rand -base64 32
GLUECO_PRIVATE_KEY=

# Secret for signing connection handles (any random string, 32+ chars recommended)
# Generate with: openssl rand -base64 32
DEMO_HANDLE_SECRET=

# Optional: next private key for rotation (set before calling /api/rotate)
GLUECO_NEXT_PRIVATE_KEY=
